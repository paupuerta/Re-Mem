# Database Configuration
DATABASE_URL=postgres://re_mem:password@localhost:5432/re_mem

# OpenAI Configuration (for AI-powered answer validation)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: set for OpenAI-compatible providers (OpenRouter, Groq, local gateway)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Gemini OpenAI-compatible example:
# OPENAI_API_KEY=your_gemini_api_key_here
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_CHAT_MODEL=gemini-2.5-pro
# OPENAI_EMBEDDING_MODEL=gemini-embedding-001

# JWT Configuration
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRATION_DAYS=7

# Logging Configuration
RUST_LOG=info
# For more verbose logging:
# RUST_LOG=re_mem=debug,axum=info

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Environment
ENVIRONMENT=development
